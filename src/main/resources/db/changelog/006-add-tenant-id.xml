<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:ext="http://www.liquibase.org/xml/ns/dbchangelog-ext"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="006-add-tenant-id-to-tables" author="jules">
        <addColumn tableName="user_phone_numbers">
            <column name="tenant_id" type="BIGINT" defaultValueNumeric="1">
                <constraints nullable="false"/>
            </column>
        </addColumn>
        <addForeignKeyConstraint baseTableName="user_phone_numbers" baseColumnNames="tenant_id" referencedTableName="tenants" referencedColumnNames="id" constraintName="fk_phone_tenant"/>

        <addColumn tableName="two_step_challenges">
            <column name="tenant_id" type="BIGINT" defaultValueNumeric="1">
                <constraints nullable="false"/>
            </column>
        </addColumn>
        <addForeignKeyConstraint baseTableName="two_step_challenges" baseColumnNames="tenant_id" referencedTableName="tenants" referencedColumnNames="id" constraintName="fk_challenge_tenant"/>

        <addColumn tableName="user_sessions">
            <column name="tenant_id" type="BIGINT" defaultValueNumeric="1">
                <constraints nullable="false"/>
            </column>
        </addColumn>
        <addForeignKeyConstraint baseTableName="user_sessions" baseColumnNames="tenant_id" referencedTableName="tenants" referencedColumnNames="id" constraintName="fk_session_tenant"/>

        <addColumn tableName="password_histories">
            <column name="tenant_id" type="BIGINT" defaultValueNumeric="1">
                <constraints nullable="false"/>
            </column>
        </addColumn>
        <addForeignKeyConstraint baseTableName="password_histories" baseColumnNames="tenant_id" referencedTableName="tenants" referencedColumnNames="id" constraintName="fk_password_history_tenant"/>

        <addColumn tableName="role_permissions">
            <column name="tenant_id" type="BIGINT" defaultValueNumeric="1">
                <constraints nullable="false"/>
            </column>
        </addColumn>
        <addForeignKeyConstraint baseTableName="role_permissions" baseColumnNames="tenant_id" referencedTableName="tenants" referencedColumnNames="id" constraintName="fk_role_permissions_tenant"/>

        <addColumn tableName="user_roles">
            <column name="tenant_id" type="BIGINT" defaultValueNumeric="1">
                <constraints nullable="false"/>
            </column>
        </addColumn>
        <addForeignKeyConstraint baseTableName="user_roles" baseColumnNames="tenant_id" referencedTableName="tenants" referencedColumnNames="id" constraintName="fk_user_roles_tenant"/>

        <addColumn tableName="group_permissions">
            <column name="tenant_id" type="BIGINT" defaultValueNumeric="1">
                <constraints nullable="false"/>
            </column>
        </addColumn>
        <addForeignKeyConstraint baseTableName="group_permissions" baseColumnNames="tenant_id" referencedTableName="tenants" referencedColumnNames="id" constraintName="fk_group_permissions_tenant"/>
    </changeSet>
<changeSet id="1783768576771-1" author="seyyed">
    <addColumn tableName="activity_logs">
        <column name="tenant_id" type="BIGINT" defaultValueNumeric="1">
            <constraints nullable="false"/>
        </column>
    </addColumn>
    <addForeignKeyConstraint baseTableName="activity_logs" baseColumnNames="tenant_id" referencedTableName="tenants" referencedColumnNames="id" constraintName="fk_activity_logs_tenant"/>
</changeSet>
</databaseChangeLog>
